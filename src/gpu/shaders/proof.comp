#version 450
// Proof-of-life compute: out[i] = in[i] * 2 + 1. Verified on the CPU side.
layout(local_size_x = 64) in;
layout(std430, binding = 0) buffer Buf { float data[]; };
layout(push_constant) uniform PC { uint count; } pc;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < pc.count) data[i] = data[i] * 2.0 + 1.0;
}
