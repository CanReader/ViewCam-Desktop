{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build — full symbols, no optimisation, assertions enabled",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0 -fno-omit-frame-pointer"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build — optimised, stripped, LTO enabled",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
      }
    },
    {
      "name": "release-msvc",
      "displayName": "Release (MSVC 2022 x64)",
      "description": "Release build using MSVC 2022 — deploys to bin/",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/release-msvc",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "Qt6_DIR": "C:/Qt/6.8.2/msvc2022_64/lib/cmake/Qt6"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "release-msvc",
      "displayName": "Build Release (MSVC)",
      "configurePreset": "release-msvc",
      "configuration": "Release"
    }
  ]
}
